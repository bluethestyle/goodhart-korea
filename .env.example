# API 키 템플릿 — 실제 키는 .env에 입력 (gitignored)
# 각 사이트 회원가입 → 활용신청 → 키 발급

OPENFISCAL_KEY=        # https://www.openfiscaldata.go.kr/ — 열린재정정보 (월별 집행 VWFOEM)
KOSIS_KEY=             # https://kosis.kr/openapi/ — 국가통계포털 (10분야 outcome)
BOK_KEY=               # https://ecos.bok.or.kr/ — 한국은행 ECOS (CPI, ICT)
DATA_GO_KR_KEY_ENC=    # https://www.data.go.kr/ — 공공데이터포털 (encoded, URL용)
DATA_GO_KR_KEY_DEC=    # 동일 — decoded (Authorization 헤더용)
